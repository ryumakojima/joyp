---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import { Picture } from 'astro:assets';
import { siteConfig, getSignupUrl } from '../../config';

import heroContact from '../../assets/photos/hero-contact.jpg';
import featureContact from '../../assets/photos/feature-contact.jpg';

const signup = getSignupUrl('ja');
const signupExternal = signup.startsWith('http');
---

<BaseLayout
  title="お問い合わせ｜日本とオセアニアの交流コミュニティ JOYP"
  description="Japan-Oceania Young Professionalsへのお問い合わせ。日本とオセアニアの交流イベント参加、コミュニティ参加、ボランティア、提携のご相談はこちら。"
  keywords={[
    '日本 オセアニア お問い合わせ',
    '日本 オセアニア 交流コミュニティ',
    '在日 オセアニア コミュニティ 問い合わせ',
  ]}
>
  <Hero
    image={heroContact}
    alt="静かな川辺の眺め"
    eyebrow="Contact"
    headline="Say hello."
    height="short"
  />

  <section class="section section-white">
    <div class="wrap contact-grid">
      <div class="reveal">
        <SectionLabel eyebrow="Get in Touch" heading="Come to an event. Help build it." />
        <p class="lead measure">
          まずは invite list へ。第一回イベントの情報や参加方法をお知らせします。
        </p>
        <div class="actions">
          <a href={signup} class="btn btn-solid" {...(signupExternal ? { target: '_blank', rel: 'noopener' } : {})}>Get an invite</a>
        </div>

        {(siteConfig.instagram || siteConfig.x || siteConfig.email) && (
          <div class="contact-block">
            <p class="contact-eyebrow">Find us</p>
            <ul class="contact-list">
              {siteConfig.instagram && <li><a href={siteConfig.instagram} target="_blank" rel="noopener">Instagram</a></li>}
              {siteConfig.x && <li><a href={siteConfig.x} target="_blank" rel="noopener">X</a></li>}
              {siteConfig.email && <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>}
            </ul>
          </div>
        )}
      </div>

      <div class="reveal">
        <div class="feature-frame">
          <div class="ratio ratio-43">
            <Picture
              src={featureContact}
              alt="集まりの一枚"
              widths={[400, 640, 960]}
              sizes="(min-width: 900px) 42vw, 100vw"
              formats={['avif', 'webp', 'jpg']}
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .contact-block {
    margin-top: 2.5rem;
  }
  .contact-eyebrow {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-bottom: 0.7rem;
  }
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .feature-frame {
    position: relative;
    border: 6px double rgba(200, 170, 110, 0.5);
    padding: 8px;
    border-radius: 6px;
    background: var(--paper);
    box-shadow: 0 24px 50px -28px rgba(14, 40, 64, 0.5);
    transform: rotate(0.8deg);
    transition: transform 0.5s ease;
  }
  .feature-frame:hover {
    transform: rotate(0);
  }
  .feature-frame .ratio {
    border-radius: 3px;
  }
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-grid > div:last-child {
      order: -1;
    }
  }
</style>
