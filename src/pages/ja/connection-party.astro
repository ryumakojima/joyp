---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionLabel from '../../components/SectionLabel.astro';

import heroEvents from '../../assets/photos/hero-events.jpg';

const eventLd = {
  '@type': 'Event',
  name: 'Japan-Oceania Young Professionals Connection Party',
  description:
    'Japan-Oceania Young Professionalsの初回Connection Partyは、2026年11月ごろ開催予定です。日程と場所は未定です。',
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  startDate: '2026-11',
  location: {
    '@type': 'Place',
    name: '未定',
    address: {
      '@type': 'PostalAddress',
      addressCountry: 'JP',
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Japan-Oceania Young Professionals',
  },
};
---

<BaseLayout
  title="Japan-Oceania Young Professionals Connection Party｜2026年11月ごろ開催予定"
  description="Japan-Oceania Young Professionalsの初回Connection Partyは2026年11月ごろ開催予定。日程・場所・申し込み方法はいずれも未定です。"
  keywords={[
    'Japan-Oceania Young Professionals Connection Party',
    '日本 オセアニア 交流会',
    '日本 オセアニア イベント',
    '在日 オセアニア イベント',
  ]}
  jsonLd={eventLd}
>
  <Hero
    image={heroEvents}
    alt="夕方の街を見渡す眺め"
    eyebrow="First Event"
    headline="Japan-Oceania Young Professionals Connection Party"
    subhead="2026年11月ごろ開催予定。日程と場所はまだ未定です。"
    height="short"
  />

  <section class="section section-white reveal">
    <div class="wrap party-grid">
      <div>
        <SectionLabel eyebrow="First Event" heading="Connection Party" />
        <p class="lead">
          オセアニアに関心のある日本の方と、日本で暮らすオセアニアにルーツのある方が、
          気軽に出会える最初のイベントです。
        </p>
      </div>

      <aside class="event-card">
        <dl>
          <div>
            <dt>Timing</dt>
            <dd>2026年11月ごろ</dd>
          </div>
          <div>
            <dt>Date</dt>
            <dd>未定</dd>
          </div>
          <div>
            <dt>Venue</dt>
            <dd>未定</dd>
          </div>
          <div>
            <dt>Sign-up</dt>
            <dd>未定</dd>
          </div>
        </dl>
        <p class="event-note">申し込みは開催が近づいたら開始します。またのぞいてみてください。</p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .party-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .party-grid p {
    color: var(--text-soft);
  }
  .event-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--paper);
    padding: 1.5rem;
  }
  .event-card dl {
    display: grid;
    gap: 1rem;
    margin: 0 0 1.4rem;
  }
  .event-card div {
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.85rem;
  }
  .event-card div:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }
  .event-card dt {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-bottom: 0.2rem;
  }
  .event-card dd {
    margin: 0;
    color: var(--text);
    font-weight: 600;
  }
  .event-note {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-soft);
  }
  @media (max-width: 860px) {
    .party-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
